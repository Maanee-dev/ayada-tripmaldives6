# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://www.ayada.tripmaldives.co/"

# API URL (used by frontend to call backend)
# In development, leave empty or set to http://localhost:3000
# In production, set to your backend URL (e.g., https://ayada.tripmaldives.co)
VITE_API_URL=

# Backend Security (Secret key to authorize frontend requests)
BACKEND_API_KEY="ayada_secret_key_2024"
VITE_BACKEND_API_KEY="ayada_secret_key_2024"

# SUPABASE_URL: The URL of your Supabase project.
VITE_SUPABASE_URL="https://zocncwchaakjtsvlscmd.supabase.co"
# SUPABASE_ANON_KEY: The anonymous key for your Supabase project.
VITE_SUPABASE_ANON_KEY="sb_publishable_Ot34P55l4JGe2RjZywLovA_UokWsJ0I"
# SUPABASE_SERVICE_ROLE_KEY: Required for server-side Supabase operations (bypass RLS).
SUPABASE_SERVICE_ROLE_KEY="sb_publishable_Ot34P55l4JGe2RjZywLovA_UokWsJ0I"

# SMTP Configuration (Hostinger)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=465
